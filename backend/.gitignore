# ==============================
# Backend-Specific .gitignore
# ==============================
# This file contains patterns specific to the backend directory.
# The root .gitignore covers general patterns that apply recursively.
# Only add backend-specific patterns here to avoid duplication.
#
# NOTE: Patterns in root .gitignore already cover:
# - node_modules/, dist/, *.tsbuildinfo
# - logs/, *.log, npm-debug.log*, yarn-*.log*
# - .env, .env.local, .env.*.local, backend/.env.test
# - coverage/, .nyc_output/
# - IDE files (.vscode/, .idea/, *.swp, *.swo, *~)
# - OS files (.DS_Store, Thumbs.db)
# - Cache files (.eslintcache, .prettiercache)
# ==============================

# ==============================
# 1. BACKEND TEST & DEBUG SCRIPTS
# ==============================
# One-off test scripts and debug utilities (not part of Jest test suite)
# These are temporary scripts used for manual testing and debugging
test-*.js
test-output.txt

# Test data files generated during manual testing
*_test.json
*test.json

# ==============================
# 2. MIGRATION & SCHEMA UTILITIES
# ==============================
# Migration runner scripts (temporary utilities for database migrations)
# These are one-off scripts used to run specific migrations
run-complete-migrations.js
run-fixed-migrations.js
run-migrations.js
run-platform-expansion-migrations.js
run-schema.js

# ==============================
# 3. VALIDATION & VERIFICATION SCRIPTS
# ==============================
# Environment validation and verification scripts
# These are utility scripts for setup and verification
validate-env.js
verify-phase0.js

# ==============================
# 4. GENERATION UTILITIES
# ==============================
# Script to generate hashes (one-off utility)
generate-hashes.js

# ==============================
# 5. BACKEND-SPECIFIC DATABASE FILES
# ==============================
# Local database files (if SQLite or similar is used for local testing)
# Note: PostgreSQL is used in production, but local testing may use SQLite
*.sqlite
*.sqlite3
*.db

# Redis dump files (if Redis is run locally with persistence)
dump.rdb

# ==============================
# 6. BACKEND-SPECIFIC TEMPORARY FILES
# ==============================
# Temporary files generated during backend operations
*.tmp
*.temp
*.bak
*.backup

# ==============================
# 7. BACKEND-SPECIFIC CACHE DIRECTORIES
# ==============================
# Backend-specific cache directories not covered by root .gitignore
.cache/
tmp/
temp/

# ==============================
# 8. BACKEND-SPECIFIC ENVIRONMENT FILES
# ==============================
# Additional backend environment files (not covered by root .gitignore)
# Root already covers: .env, .env.local, .env.*.local, .env.development, .env.staging, .env.test, backend/.env.test
# Add any other backend-specific env files here if needed

# ==============================
# 9. BACKEND-SPECIFIC BUILD ARTIFACTS
# ==============================
# Backend-specific build outputs (root covers dist/, but adding for clarity)
# This is redundant with root .gitignore but makes it explicit for backend
# dist/
